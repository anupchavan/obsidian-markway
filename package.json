{
    "name": "markway",
    "version": "0.1.2",
    "description": "Sync Apple services with Obsidian",
    "main": "main.js",
    "type": "module",
    "scripts": {
        "dev": "node esbuild.config.mjs",
        "build": "tsc -noEmit -skipLibCheck && node esbuild.config.mjs production",
        "version": "node version-bump.mjs && git add manifest.json versions.json",
        "lint": "eslint . --config eslint.config.mts --max-warnings=0",
        "watch:created-sync": "node scripts/watch-created-sync.mjs",
        "test": "vitest run",
        "test:watch": "vitest"
    },
    "keywords": [],
    "license": "0-BSD",
    "devDependencies": {
        "@eslint/js": "^9.39.4",
        "@eslint/json": "^2.0.0",
        "@types/node": "^25.9.2",
        "esbuild": "^0.28.0",
        "eslint": "^9.39.4",
        "eslint-plugin-obsidianmd": "^0.3.0",
        "globals": "^17.6.0",
        "jiti": "^2.7.0",
        "tslib": "^2.8.1",
        "typescript": "^6.0.3",
        "typescript-eslint": "^8.60.1",
        "vitest": "^4.1.8"
    },
    "dependencies": {
        "dayjs": "^1.11.21",
        "obsidian": "latest"
    }
}
